-- 여기서부터는 게시글 26 윈도우 함수
-- window 함수는 최초의 from table에서 파티션을 생성후 원본set (from table)도 유지한다. 파티션으로 생성된 결과는 sub query이다! sub query를 원본query set(from table)과 결합(join, 집합 ,...)하는 것이 목적이다
-- group by와 다르게 원본 원본set(from table)을 유지한다


select title, length, rating
from film;
-- 위의 쿼리의 결과와 아래의 group으로 구한 평균을 join 하고 싶다.

-- 윈도우 함수 없이 기존의 방식으로 group 평균 구하는 방식
SELECT rating,
       AVG(length) AS avg_length
FROM film
GROUP BY rating;

 -- 위에서 하고 싶던 쿼리 결과와 group 평균을 join하는 쿼리
SELECT f.title, f.rating, f.length, t.avg_length
FROM film f INNER JOIN (SELECT rating,
					AVG(length) AS avg_length
					FROM film
					GROUP BY rating) t
ON f.rating = t.rating
ORDER BY f.rating;

-- 위의 방식은 너무 복잡해서 윈도우 함수가 나오게 됨
-- group by한 table과 원본을 결합!

SELECT title,
       rating,
       length,
       AVG(length) OVER(PARTITION BY rating) AS avg_length
FROM film;


-- 원래 select title, 10 from category랑 select name, (select 10 as val) from category 이런 쿼리들은 join하는 거다
-- 즉 select안의 avg(length) over(partition by rating) as avg_length도 마찬가지로 join하는거다


-- ROWS/RANGE : ORDER BY옵션이 있다면 추가로 파티션을 다시 쪼개어 윈도우를 지정할 수 있다.(윈도우 슬라이딩 알고리즘을 생각하면 이해가 편할듯)
-- 여기서부터 윈도우 함수 종류
-- 1) row 함수: 각 행에 1, 2, 3, ... 순번을 부여한다. 같은 값이 있어도 번호가 겹치지 않는다.

-- partition by가 없으면 전체가 partition이 된다. group by에 아무것도 없으면 null로 되서 전체가 되는것과 같다
SELECT
    title,
    ROW_NUMBER() OVER(ORDER BY length DESC)
FROM film;


SELECT
    title,rating,
    ROW_NUMBER() OVER(partition by rating ORDER BY length DESC)r
FROM film
order by r;

-- 2, 3번
-- row_number, rank, dense_rank 통합
SELECT
    title,
    length,
    row_number() over(order by length desc) "row number", -- 같은 값이어도 공동 순위 아니고 어떤 알고리즘으로 등수를 나눈다
    RANK() OVER(ORDER BY length DESC) "rank", -- rank와 dense rank는 같은 값이면 공동으로 같은 순위이다 , rank는 공동 등수 다음에 그 공동 인원 인원만큼 플러스 해준 다음 등수
    dense_rank() over(order by length desc) "dense rank" -- dense rank는 공동 등수 인원 다음 +1 등수
FROM film;

-- 4번 
-- NTILE() 그룹 나누기
-- 데이터를 n개의 그룹으로 나눈다.
-- 상위 25% : NTLE(4)
-- 상위 10% :NTILE(10)
-- 4분위수 : NTILE(4)
-- 분위 분석 등에 사용된다
SELECT
    title,
    length,
    NTILE(4) OVER(ORDER BY length)
FROM film;


-- 5번 : -- LAG() 이전 행, 현재 행을 기준으로 이전 행의 값을 참조한다. 현재 행보다 이전 행의 값을 가져온다.
-- 주로 전일 데이터 비교, 이전 매출 비교, 증감 계산 등에 사용된다.

SELECT
    title,
    length,
    LAG(length) OVER(ORDER BY film_id)
FROM film;

select
	title,
    length,
    lag(title) over(order by length)
from film;

select
	film_id,
	title,
    length,
    lag(title) over(order by length)
from film
where film_id = 500; -- 이러면 select 실행 되기 전에 실행 되므로 film_id가 500인 하나의 테이블로 select해서 lag결과인 이전 값이 null로 나오게 된다

-- 그래서 아래와 같이 in line view 사용해야함. 

select *
from (select
	film_id,
	title,
    length,
    lag(title) over(order by length)
from film) t
where film_id = 500; 


-- 6번 : lead  다음 행 값
SELECT
    title,
    length,
    LEAD(length) OVER(ORDER BY film_id)
FROM film;



-- 7번 : CUME_DIST() 누적 분포 . 데이터가 전체에서 어느 정도 위치에 있는지 계산한다.
-- 현재 행 이하의 데이터가 전체에서 차지하는 누적 비율을 반환한다.
-- 결과는 0~1 사이의 값이다.

-- over(partition by)를 안해서 전체가 partition으로 잡힘
SELECT
    title,
    length,
    CUME_DIST() OVER(ORDER BY length)
FROM film;

-- partition by rating하면 rating 그룹 내에서 상위 몇퍼센트인지 알 수 있다
SELECT
    title,
    length,
    rating,
    CUME_DIST() OVER(partition by rating ORDER BY length)
FROM film;

-- 8번 : PERCENT_RANK() 백분위 순위. 현재 행의 백분위 순위를 반환한다.
-- 가장 작은 값은 0, 가장 큰 값은 1에 가까운 값을 가진다.
-- 마지막이 1이 아닌 이유는 같은 값들이 있어서
SELECT
    title,
    length,
    PERCENT_RANK() OVER(ORDER BY length)
FROM film;


-- 9번 : 집계 윈도우 함수
-- 각 partition(group)마다의 카운트, 총합, 평균, 최소, 최대값
SELECT
	title, 
    rating,
	COUNT(length) OVER(PARTITION BY rating), 
	SUM(length) OVER(PARTITION BY rating), 
	AVG(length) OVER(PARTITION BY rating), 
	MIN(length) OVER(PARTITION BY rating), 
	MAX(length) OVER(PARTITION BY rating)
FROM film;


-- 여기서부터는 27 게시글 윈도우 범위(rows/ range)를 사용하는 윈도우 함수
-- 계산할 행의 범위를 지정한다. ORDER BY가 없으면 행의 순서가 없기 때문에 ROWS나 RANGE를 사용할 수 없다.
-- ROWS와 RANGE는 ORDER BY를 기준으로 동작하며, PARTITION BY가 있다면 각 그룹 내부에서만 범위를 계산한다.
-- rows는 같은 값을 갖는 행도 다른 행으로 취급하나 range는 같은 값도 포함시켜서 갯수가 더 늘어날 수 있어서 애매해진다. 그래서 range는 잘 사용하지 않음

-- rows 문법에서 unbounded preceding : 처음부터   unbounded following : 마지막까지 이다. current row: 현재 행

-- 함수() over() : 전체를 하나의 partition으로, 정렬X, 윈도우 range는 처음부터 끝까지
-- 함수() over(partition by something) : n개의 partition , 정렬 X, 윈도우 range는 처음부터 끝까지
-- 함수() over(partition by something, order by somethig) n개의 partition, 정렬O, order by가 있으면 무조건 range는 생김 작성하지 않아도. 즉 윈도우의 range는 처음부터 현재 값의 range까지, rank를 예시로 보면 처음부터 해당 행까지의 rank 값
-- 즉 rank 에서 order by되있으면 전체 row를 일일히 연산 후 rank 따지지 않고 현재 row 값 이전 row 값과 비교한다. 이게 속도가 더 빠르므로. 일일히 row 마다 전체 값으로 연산하면 속도가 느리기 때문에
-- order by가 없으면 range의 default 값은 range between unbounded preceding and unbounded following이 되고 range를 따로 지정할 수 없다 default로 고정 즉 전체가 range로 됨 default로.
select
	title, -- order by가 있으면 range의 default 값은 range between unbounded preceding and current row
    rank() over(order by lengtgh desc) -- range between unbounded preceding and current row가 생략되있는 것으로 이걸 넣은것과 결과가 같다. current row대신 unbounded following으로 해도 같으나 해당 
from film; -- partition by는 생략되있으므로 전체가 하나의 partition으로 잡힘


-- rank() 내부에 매개값이 없다 이미 order by에서 지정된거로 동작하므로.

-- sum()은 내부에 order by의 변수와 다른 매개변수가 와도 된다. 당연하다
select
	title,
    length,
	sum(length) over(order by length desc
					range between unbounded preceding and current row) -- range가 없으면 처음부터 해당 row값까지의 합계가 된다.  위에 range default값은 처음부터 해당 row까지이므로.
from film; -- 그러나 해당 row의 같은 값들이 있으면 같은 값을 갖는 모든 행을 해당 row로 취급해서 합이 이상해진다. 같은 값을 갖는 row들끼리를 구분하고 포함시키려면 row between unbounded preceding and current row로 해야함. range -> row로 바꾼다
				
select
	title,
    length,
	sum(length) over(order by length desc
					 range between unbounded preceding and current row) 값범위누적,
	sum(length) over(order by length desc
					 rows between unbounded preceding and current row) 행범위누적,
				
	sum(length) over(order by length desc
					 rows between unbounded preceding and unbounded following) 전체합
from film;

-- 다시 강조하지만 order by가 없으면 range는 처음부터 끝까지로 고정되고 따로 다른 range로 지정할 수 없다
-- order by가 있으면 range는 처음부터 현재 row까지로 default이나 다른 range를 지정할 수 있다.




-- 1) 상영시간의 누적합
SELECT
    title,
    length,
    SUM(length) OVER(
        ORDER BY length
        ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW -- 생략하면 range가 되서 rows~ 사용
    ) AS cumulative_length
FROM film;


-- 2) 최근 3개 영화의 평균 상영시간 : 이전 2행 + 현재 (최근 3건 평균)
-- 현재 영화와 바로 앞의 2편을 포함한 3편의 평균 상영시간을 구한다. 
-- 동작 방식이 sliding window랑 유사
SELECT
    title,
    length,
    AVG(length) OVER(
        ORDER BY length
        ROWS BETWEEN 2 PRECEDING AND CURRENT ROW
    ) AS avg_length
FROM film;

-- 3)  최근 3개 영화의 평균 상영시간 : 이전 1행 + 현재 + 다음 1행
-- 현재 영화를 중심으로 앞뒤 1편씩 포함한 3편의 평균 상영시간을 구한다.
SELECT
    title,
    length,
    AVG(length) OVER(
        ORDER BY length
        ROWS BETWEEN 1 PRECEDING AND 1 FOLLOWING
    ) AS neighbor_avg
FROM film;


-- 4) 현재부터 마지막까지 (남은 데이터 누계). 현재 영화부터 마지막 영화까지의 상영시간 합계
SELECT
    title,
    length,
    SUM(length) OVER(
        ORDER BY length
        ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING
    ) AS remaining_length
FROM film;

-- PARTITION BY + ORDER BY + ROWS를 모두 사용하는 예
SELECT
    p.staff_id,
    DATE(p.payment_date) AS pay_date,
    SUM(p.amount) AS daily_amount
FROM payment p
GROUP BY
    p.staff_id,
    DATE(p.payment_date); -- group by 두 항목(직원, 날짜) 직원별 날짜별 매출의 합을 구한 것
    
    
    
    -- 이제 이걸 table로 이용해서 일주일치 매출을 따져보자. with alias_name as x 이용
    -- 이전 6일 + 현재일 = 7일의 매출 합계

with ds as
(
SELECT
    p.staff_id,
    DATE(p.payment_date) AS pay_date,
    SUM(p.amount) AS daily_amount
FROM payment p
GROUP BY
    p.staff_id,
    DATE(p.payment_date) -- group by 두 항목(직원, 날짜) 직원별 날짜별 매출의 합을 구한 것 
)

select staff_id,   pay_date, daily_amount,
-- 이전 6일 +현재일 매출합계를 넣자
sum(daily_amount) over(partition by staff_id
						order by pay_date 
                        rows between 6 preceding and current row) "7days"
from ds -- with ds as 쿼리 사용해서 엄청 짧아졌다.
order by pay_date asc;


-- 중간에 빠진 날짜 없이 staff_id 1,2의 일주일 매출 1위 날짜를 출력해보자
-- with를 세번 사용해서 해보자
with daily_sales as
(
SELECT
    p.staff_id,
    DATE(p.payment_date) AS pay_date,
    SUM(p.amount) AS daily_amount
FROM payment p
GROUP BY
    p.staff_id,
    DATE(p.payment_date) -- group by 두 항목(직원, 날짜) 직원별 날짜별 매출의 합을 구한 것 
),
rolling_sales as (
select staff_id,   pay_date, daily_amount,
-- 이전 6일 +현재일 매출합계를 넣자
sum(daily_amount) over(partition by staff_id
						order by pay_date 
                        rows between 6 preceding and current row) "rolling_7days"
from daily_sales -- 
),
ranked as (
	select *,
    row_number() over(partition by staff_id order by rolling_7days desc) rn
    from rolling_sales
)
select staff_id,
	   date_sub(pay_date, interval 6 day) start_day,
       pay_date end_day,
       rolling_7days
from ranked
where rn = 1;
