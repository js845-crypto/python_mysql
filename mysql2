-- 여기서부터는 숫자/문자/날짜 타입의 단일행 함수

-- 단일행 함수(Single Row Function)는 한 행의 데이터를 입력받아 한 행의 결과를 반환하는 함수이다.
-- 즉 행의 갯수만큼 함수가 실행됨
-- 예를 들어 고객이 599명이면 함수도 599번 실행되어 599개의 결과를 반환한다.

SELECT
    first_name,
    lower(first_name) AS lower_name
FROM customer
where first_name like 'a%';

SELECT
    first_name,
    SUBSTRING(first_name, 2, 3) AS sub_name -- index 2부터 3개를 slicing, mysql은 index1부터 시작
FROM customer;

-- 고객 이름과 성을 합치고 이름 길이를 함께 출력
SELECT
    CONCAT(first_name, ' ', last_name) AS full_name,
    LENGTH(first_name) AS name_length
FROM customer;

SELECT
    customer_id,
    MOD(customer_id, 10) AS remainder, -- mod랑 %랑 연산 똑같다
    customer_id%10
FROM customer;

SELECT
    customer_id,
    FLOOR(RAND() * 100) + 1 AS coupon_number -- rand는 0부터 1사이의 숫자를 랜덤으로 뽑으므로 저 코드는 1~100사이의 랜덤 숫자
FROM customer
LIMIT 10;

SELECT
    payment_id,
    amount,
    ROUND(amount, 1) AS round_amount -- 소수 첫째자리까지 반올림
FROM payment;


-- 10% 할인된 금액 구하기. 반올림 소수점 2까지
SELECT
    payment_id,
    amount,
    ROUND(amount * 0.9, 2) AS discount_price
FROM payment
LIMIT 10;



