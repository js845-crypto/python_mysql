 -- CAST() 함수 : type 변환 함수, cast(인수 as type) -> 인수를 type로 강제로 변환
SELECT CAST('100' AS float) AS result; -- 컬럼 없이  값이나 계산식을 SELECT로 조회시 FROM절 생략
 
SELECT CAST('100' AS unsigned) AS result; -- unsigned대신 int하면 오류남

-- 문자열끼리 더하기 자동 형변환(MySQL에선 +연산이 숫자 연산에만 사용된다)
SELECT '100' + '200' AS result; -- 100, 200 둘다 type 변환
SELECT '100' + 50; -- 100이 type 변환
SELECT '100원' + 50; -- 100원이라고 글자가 포함되있어도 자동 type 변환,
select '100원' + '$50'+ 50; -- 문자로 시작하면 0으로 변환, $50은 0으로 변환
SELECT 'xyz' + 50; -- 문자로 시작하면 0으로 변환


