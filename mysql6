-- 여기서부터는 집합 쿼리
-- 집합 쿼리는 두개 이상의 select 결과물을 합치는 것
use sakila;

SELECT first_name
FROM actor;

select first_name
from customer;

-- select first_name 두개의 결과를 합쳐줌 , 다만 중복을 제거함 , 중복을 제거하려면 union all 해야함, 속도는 union all이 훨씬 빠르다

select first_name
from actor
union
select first_name
from customer;

-- 두개가 겹치면 첫번째 column이 나온다. 아니면 as로 별칭을 주면 된다. 또한 column명이 달라도 상관없다 data type만 체크함.
select t.name
from
(select first_name as name from actor
union
select last_name as name from customer) t
where t.name like '%ab%';


select count(*) from
(select first_name
from actor
union
select first_name
from customer) t;

-- 교집합
select first_name
from actor
intersect
select first_name
from customer;

