-- scalar subquery
-- 위와같이 두개의 query로 하지말고 하나의 query로 하자, 이것이 subquery 이용
select
	title,
    length,
    (select round(avg(length)) from film) 전체평균 -- subquery
from film;

select
	title,
    length,
    (select avg(length), sum(length) from film) 전체평균 -- select subquery는 무조건 하나의 scalar 값으로 나와야함, 오류 발생
from film;


select
	title,
    length,
    (select title from film) -- 이것도 오류 발생한다 단일 row 또는 column 값이 아니라서
from film;


select
	title,
    length,
    (select title from film where film_id = 1) -- 단일 scalar 값이라서 오류 발생 안한다.
from film;


-- inline view
-- FROM절에 사용하는 서브쿼리 , 실행 결과를 임시 테이블(View)처럼 사용

select t.title
from (select * from film where length > 120) t -- as가 필요함 
where t.title like 'b%';


select  title
from film
where title like 'b%' and length > 120; -- 위의 코드와 동일하다, 그러나 이 코드가 속도가 더 빨라서 mysql 자체에서 이렇게 바꿔버린다
-- 중요한 것은 from 절에서 select가 올 수 있고 이것을 inline view라고 한다


-- where 절에 사용하는 서브 쿼리, 단일 행, 다중 행 결과 반환 가능

select avg(length) from film;

select *
from film
where length > (select avg(length) from film);

-- 요약 : select절 ( scalar subquery)
--       from절( inline view )
--      where 절( subquery )


-- inline view 예제
SELECT *
FROM (
    SELECT title, rental_rate
    FROM film
) AS f
WHERE rental_rate >= 4.99;	


-- where 절 subquery 예제
SELECT title, length
FROM film
WHERE length > (
    SELECT AVG(length)
    FROM film
);


-- where 절 subquery에 자주 사용되는 연산자

select *
from film
where rental_rate > (select avg(rental_rate) from film);

select *
from film
where rating = (select rating from film
					where title = 'ADAPTATION HOLES' or title = 'ACE GOLDFINGER'); -- 오류 발생한다 = 연산자 사용할 땐 where 절에서 subquery로 하나의 값만 나와야함
select *
from film
where rating in (select rating from film
					where title = 'ADAPTATION HOLES' or title = 'ACE GOLDFINGER'); -- in을 사용하면 오류가 없음 실행됨. rating이 G, NC17 둘중에 만족되는 것을 출력


select *
from film
where rating not in (select rating from film
					where title = 'ADAPTATION HOLES' or title = 'ACE GOLDFINGER');

select *
from film
where (rating , rental_rate) >  -- column은 여러개여도 상관이 없다 row가 문제이다, 오류 안생김, 우측에 여러값이 오면 좌측에도 여러 값을 받아주는 vector 형태로 오면 된다
	(select rating, rental_rate from film
    where title = 'ACE GOLDFIKNGER');


