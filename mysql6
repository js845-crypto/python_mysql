-- self join


-- self cross join는 student table 내에서 팔로우 하는 최대의 경우의 수
select *
from student s1 cross join student s2 -- cross join은 on조건이 필요없다, 또한 from -> join -> where 순서로 실행된다 유의
where s1.student_name <> s2.student_name;  -- 자기 자신은 빼야함

select count(*)
from student s1 cross join student s2 -- cross join은 on조건이 필요없다, 또한 from -> join -> where 순서로 실행된다 유의
where s1.student_name <> s2.student_name;  -- 자기 자신은 빼야함

