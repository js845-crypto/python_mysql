-- 게시글 28 recursive cte (with table)을 사용한 계층형 데이터 조회

-- 1) CEO부터 모든 직원 조회
CREATE TABLE emp (
    emp_id INT PRIMARY KEY,
    emp_name VARCHAR(30) NOT NULL,
    manager_id INT NULL,
    FOREIGN KEY (manager_id) REFERENCES emp(emp_id) -- 외래key가 자기자신 테이블의 key를 참조
);


INSERT INTO emp VALUES
(1, 'CEO', NULL),
(2, '영업본부장', 1),
(3, '개발본부장', 1),
(4, '관리본부장', 1),
(5, '영업팀장', 2),
(6, '해외영업팀장', 2),
(7, '백엔드팀장', 3),
(8, '프론트팀장', 3),
(9, '인사팀장', 4),
(10, '신입사원A', 7),
(11, '신입사원B', 8);


WITH RECURSIVE emp_tree AS
(
    -- 시작점
    SELECT
        emp_id,
        emp_name,
        manager_id,
        1 AS level -- 시작 행(ROOT)의 레벨값은 1
    FROM emp
    WHERE manager_id IS NULL -- 시작 행(ROOT)의 조건

    UNION ALL

    -- 하위 직원 계속 찾기, 끝날때 까지 재귀(자기 자신을 이용해서 같은 작업을 반복) 호출
    SELECT
        e.emp_id,
        e.emp_name,
        e.manager_id,
        t.level + 1
    FROM emp e INNER JOIN emp_tree t
         ON e.manager_id = t.emp_id
)

SELECT *
FROM emp_tree;


-- 2) 조직도 형태로 조회

WITH RECURSIVE emp_tree AS
(
    SELECT
        emp_id,
        emp_name,
        manager_id,
        1 level
    FROM emp
    WHERE manager_id IS NULL

    UNION ALL

    SELECT
        e.emp_id,
        e.emp_name,
        e.manager_id,
        t.level + 1
    FROM emp e
    JOIN emp_tree t
      ON e.manager_id=t.emp_id
)

SELECT
    CONCAT(REPEAT('    ', level-1), emp_name) AS organization
FROM emp_tree;


-- 3) 전체 계층 경로(Path)를 같이 조회

WITH RECURSIVE emp_tree AS
(
    SELECT
        emp_id,
        emp_name,
        manager_id,
        emp_name AS path
    FROM emp
    WHERE manager_id IS NULL

    UNION ALL

    SELECT
        e.emp_id,
        e.emp_name,
        e.manager_id,
        CONCAT(t.path,' > ',e.emp_name)
    FROM emp e
    
    JOIN emp_tree t
      ON e.manager_id=t.emp_id
)

SELECT *
FROM emp_tree;

    
-- 4) 특정 직원의 모든 부하직원 조회
WITH RECURSIVE emp_tree AS
(
    SELECT *
    FROM emp
    WHERE emp_name='개발본부장'

    UNION ALL

    SELECT e.*
    FROM emp e
    JOIN emp_tree t
      ON e.manager_id=t.emp_id
)

SELECT *
FROM emp_tree;




