create database test;

show tables;

create table product(
	id int auto_increment primary key,
    name varchar(30),
    price int
);

-- DDL에는 create / drop / alter가 있다. 근데 그냥 table에 우측 클릭 해서 drop, alter table하는게 더 편함
-- DML에는 insert / update / delete / select가 있고 select가 데이터 분석가한테 제일 중요함
 

-- 아래부터는 DML 이고 test.product() 해야하지만 이미 들어와있으므로 생략 가능. 컬럼 순서와 value 순서를 맞춰야함 
-- name부터 쓰자 id는 자동임
-- 작은 따옴표로 써야함 무조건 문자열
 insert into product(name, price)
 values('마우스', 3000);
 select * from product;
 
 update product 
 set price = 50000
 where id = 1 ;
 delete from product where id = 10;
 SET SQL_SAFE_UPDATES = 0;
 INSERT INTO product(name)
VALUES('모니터');
