
select * from country where country_id = 86; -- 대한민국 나라의 primary key = 86

select * from city
where country_id = 86; -- 대한민국이라는 country에 city가 5개 연결되잇다. 1:5 관계


-- inner join : 양쪽에 같은 key 있는 두개의 table 연결, 
-- city와 country 두개의 테이블을 country_id로 join!
-- city의 country_id는 FK, country의 country_id는 PK
select
	ci.city, ci.country_id, co.country
from city ci
inner join country co
on ci.country_id = co.country_id
where ci.country_id = 50;

