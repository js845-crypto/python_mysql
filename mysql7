-- action 최대러닝타임의 영화보다 러닝타임이 긴 영화들 조회
with f3join as
(select c.name name, f.title title, f.length length
from category c
join film_category fc
on c.category_id = fc.category_id
join film f
on fc.film_id = f.film_id)

select *
from film
where length > (select max(length)
				from f3join
				where name = 'Action');

select max(length)
from f3join
where name = 'Action'
group by null;


