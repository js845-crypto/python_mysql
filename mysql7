-- 영화에 출연한 배우목록
SELECT
    f.title,
    GROUP_CONCAT(
        CONCAT(a.first_name, ' ', a.last_name)
        ORDER BY a.last_name
        SEPARATOR ', '
    ) AS actors
FROM film f
INNER JOIN film_actor fa
    ON f.film_id = fa.film_id
INNER JOIN actor a
    ON fa.actor_id = a.actor_id
GROUP BY f.film_id, f.title
ORDER BY f.title;

-- 위에 보다 간단하게 
-- 영화에 출연한 배우목록
SELECT
    f.title,
    -- a.first_name          group by f.title하면 이거 주석처리해야 오류 안남
    count(*),
    group_concat(a.first_name order by a.first_name) 출연배우
FROM film f
INNER JOIN film_actor fa
    ON f.film_id = fa.film_id
INNER JOIN actor a
    ON fa.actor_id = a.actor_id
group by f.title


SELECT
    c.name,
    COUNT(*) AS movie_count,
    GROUP_CONCAT(f.title ORDER BY f.title)
FROM category c
JOIN film_category fc
ON c.category_id = fc.category_id
JOIN film f
ON fc.film_id = f.film_id
GROUP BY c.name
HAVING COUNT(*) >= 60
order by count(*) desc;


SELECT
    c.name,
    COUNT(DISTINCT f.rating) AS rating_count중복제거카운트, 
    COUNT(*) AS 영화수
FROM category c
JOIN film_category fc
ON c.category_id = fc.category_id
JOIN film f
ON fc.film_id = f.film_id
GROUP BY c.name;



SELECT
    c.name,
    avg(f.length) 평균,
    VARIANCE(f.length) AS "분산(평균과의 거리에 제곱)",
    STDDEV(f.length) AS "표준편차(분산에 제곱근)"
FROM category c
JOIN film_category fc
ON c.category_id = fc.category_id
JOIN film f
ON fc.film_id = f.film_id
GROUP BY c.name;


SELECT
    c.name,
    avg(f.length) 평균,
    VARIANCE(f.length) AS "분산(평균과의 거리에 제곱)",
    STDDEV(f.length) AS "표준편차(분산에 제곱근)"
FROM category c
JOIN film_category fc
ON c.category_id = fc.category_id
JOIN film f
ON fc.film_id = f.film_id
GROUP BY c.name
ORDER BY STDDEV(f.length) ASC;


