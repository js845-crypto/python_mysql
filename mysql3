-- 영화 러닝타임으로 구분
SELECT
    title, -- column
    length, -- column
    IF(length >= 120, '장편', '일반') AS movie_type -- 계산된 값
FROM film
order by movie_type asc, length asc; -- 일반을 먼저 정렬시킨다 그 후에 장편, 만약 movie_type 동일하면 length로 정렬

-- 대여기간으로 구분
SELECT
    title,
    rental_duration,
    IF(rental_duration >= 5, '길다', '짧다') AS duration_type
FROM film;


-- film 테이블은 대부분 NULL이 없지만, 만약 original_language_id가 NULL이면 0을 출력한다.
SELECT
    title,
    language_id,
    original_language_id,
    IFNULL(original_language_id, 0) AS language_id
FROM film;


-- rental_rate = 4.99이면 null로 바꿈
SELECT
    title,
    rental_rate,
    NULLIF(rental_rate, 4.99) AS result
FROM film;

-- db를 sakila에서 test로 옮긴 후 table을 product 하나 만든 후에 nullif, ifnull을 실습해보자

CREATE TABLE product (
    id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(30),
    price INT,
    discount INT
);

INSERT INTO product(name, price, discount)
VALUES
('노트북', 1500000, 10),
('마우스', 30000, NULL),
('키보드', NULL, 15),
('모니터', 250000, NULL),
('스피커', NULL, NULL);

select * from product;

SELECT
	id,
    name,
    IFNULL(price, 0) AS price,
    nullif(discount, 15) as discount
FROM product;


-- coalesce : 인수 중에 처음으로 null이 아닌 값을 반환
SELECT
    name,
    COALESCE(price, discount, 0) AS value
FROM product;

SELECT *
FROM product
WHERE price IS NULL;

SELECT *
FROM product
WHERE discount IS NOT NULL;

-- 노트북이면 1, 마우스면 2, 나머지는 3
select
	name,
	if(name = '노트북', 1, if(name = '마우스', 2, 3 ))
from product;

-- if()함수 == case 표현식 이지만 조건의 경우가 많아지면 , 즉 중첩이 많아지면 가독성이 떨어지므로 case 표현식 사용하자
-- if()는 mysql에만 있음, case는 표현식은 표준이라 다른 곳에도 있음
-- case는 항상 end로 끝나야한다 ! 그리고 as 할거면 end문에 적어야함


-- 다시 sakila로 돌아가서 case문 사용해보자

SELECT
    title,
    length,
    CASE
        WHEN length >= 150 THEN '매우 김'
        WHEN length >= 120 THEN '장편'
        WHEN length >= 90 THEN '보통'
        ELSE '단편'
    END AS length_type
FROM film;

SELECT
    title,
    rental_rate,
    CASE
        WHEN rental_rate = 0.99 THEN '저가'
        WHEN rental_rate = 2.99 THEN '중가'
        WHEN rental_rate = 4.99 THEN '고가'
        ELSE '기타'
    END AS price_type
FROM film;


SELECT
    title,
    rating,
    CASE rating
        WHEN 'G' THEN '전체관람가'
        WHEN 'PG' THEN '부모지도'
        WHEN 'PG-13' THEN '13세 이상'
        WHEN 'R' THEN '청소년 제한'
        WHEN 'NC-17' THEN '17세 이상'
        ELSE '기타'
    END AS rating_name
FROM film;

-- where절에서 사용 예
-- 상영시간이 120분 이상이면 rental_rate >= 2.99 인 영화 조회
-- 120분 미만이면 rental_rate >= 0.99인 영화 조회
SELECT
    title,
    length,
    rental_rate
FROM film
WHERE IF(length >= 120, -- length가 120이상이면 where에 rental_rate >=2.99이고 length가 120 미만이면 where에 rental_rate >=0.99가 적용된다, 즉 if가 먼저 계산되서 반환되고 where에 들어가는 것
         rental_rate >= 2.99,
         rental_rate >= 0.99);


-- rating이 G이면 90분 이상 조회, 아니면 120분 이상 조회
SELECT
    title,
    rating,
    length
FROM film
WHERE IF(rating = 'G',
         length >= 90,
         length >= 120);
         


-- original_language_id가 NULL이면 >=연산자를 사용할 수 없기때문에 NULL이면 0으로 바꿔 비교
SELECT
    title,
    original_language_id
FROM film
WHERE IFNULL(original_language_id, 0) >= 10;


SELECT
    title,
    original_language_id
FROM film
-- WHERE IFNULL(original_language_id, 0) = 0 ; 이것과 동일한 코드는 아래에 있다.
where original_language_id is null or original_language_id = 0;


SELECT
    title,
    rental_rate
FROM film
WHERE NULLIF(rental_rate, 4.99) IS NULL;
-- where rental_rate is null or rental_rate = 4.99랑 같다



-- where 절에 case 사용한 코드
-- G 등급은 90분 이상, 그 외는 120분 이상 조회
SELECT
    title,
    rating,
    length
FROM film
WHERE
CASE
    WHEN rating = 'G'
        THEN length >= 90
    ELSE
        length >= 120
END;

-- order by 절에서 조건문 사용해보자
SELECT
    title,
    length
FROM film
ORDER BY length ASC;

-- 120분보다 작은 영화와 120분 이상인 영화로 구분하여 제목의 오름차순으로 조회 
SELECT
    title,
    length
FROM film
ORDER BY IF(length < 120, 0, 1) ASC, title ASC;


-- test로 db옮긴 후에 오름차순 정렬하면 NULL값은 제일 먼저 온다. 오름차순일 때 null을 맨 뒤로 정렬하고 싶으면 NULL을 100으로 바꿔 마지막에 정렬이 되게 하자. mysql에선 null이 가장 작은 값으로 간주되므로
use test;
SELECT * from product
order by ifnull(discount, 100) asc;

-- sakila로 다시 db 이동후에
-- 컬럼값으로 오름/내림이 아닌 특정 순서로 정렬
-- rating이 enum type으로 my sql에서 순서를 따로 정의해서 G -> PG -> PG-13 -> R -> NC-17 순서로 정렬한다 asc이면
-- rating이 PG-13 -> NC-17 -> 나머지는 rating과 상관없이 제목에 의해 정렬되게 하고 싶을 때
use sakila;
select title, rating from film
order by rating asc;


SELECT
    title,
    rating
FROM film
ORDER BY
CASE
    WHEN rating = 'PG-13' THEN 1
    WHEN rating = 'NC-17' THEN 2
	else 3
END asc, title asc;

-- length 150 이상인 애들 titme 순서대로 먼저 정렬 후 120 이상인 애들을 title로 정렬 후 그 다음에 나머지들은 length 상관없이 title 순서로 정렬
SELECT
    title,
    length
FROM film
ORDER BY
CASE
    WHEN length >= 150 THEN 1
    when length >= 120 then 2
    ELSE 2
END, title;


-- 여기서부터는 with문
-- 원래 db의 table 메모리에 들어가있고
-- select에서 부른 result table도 임시의 table로서 메모리에 올라간다
-- 다시말하지만 select의 결과물도 table로 메모리에 올라간다, 그러므로 as 별칭으로 from에 사용할 수 있다

select f2.제목, f2.시간
from 
(select title 제목, length 시간
from film
limit 10) as f2
where f2.시간 between 50 and 100;

-- 이렇게 table을 갔다 쓸때마다 복사 붙여넣기 번거롭고 순서 때문에 가독성이 떨어져서 with문을 사용한다

with f2 as (
	select title 제목, length 시간
from film
limit 10)
select f2.제목, f2.시간
from f2
where f2.시간 between 50 and 100;

-- film테이블에서 title, rental_rate 컬럼만을 가진 가상의 테이블
WITH movie AS (
    SELECT title, rental_rate
    FROM film
)
SELECT *
FROM movie;

--  rental_rate가 4 이상인 영화의 title, rental_rate 컬럼만을 가진 가상의 테이블
WITH expensive_movie AS (
    SELECT title, rental_rate
    FROM film
    WHERE rental_rate >= 4
)
SELECT *
FROM expensive_movie;

-- 영화 길이가 120분 이상
WITH long_movie AS (
    SELECT title, length
    FROM film
    WHERE length >= 120
)
SELECT *
FROM long_movie
ORDER BY length DESC;


-- 배우의 풀네임을 가진 가상의 테이블

WITH actor_name AS (
    SELECT
        actor_id,
        CONCAT(first_name, ' ', last_name) AS full_name
    FROM actor
)
SELECT *
FROM actor_name
ORDER BY full_name;

-- 이름에 z가 들어간 사람 가상 테이블
select *
from actor
where first_name like '%z%';

select *
from actor
where upper(first_name) like '%Z%'
or upper(last_name) like 'Z%';

-- or 사용하기 싫으면 concat

select * from actor
where upper(concat(first_name, last_name)) like '%Z%';

-- with문 사용한 코드

with a_n as (
	select actor_id, upper(concat(first_name, last_name)) fullname
    from actor
)
select * from a_n
where fullname like '%Z%';


